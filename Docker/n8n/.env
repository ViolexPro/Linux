# Версия n8n (последняя стабильная)
N8N_VERSION=latest

# Настройки PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=amd#RULES123
POSTGRES_DB=n8n

# Не-root пользователь для n8n (безопасность)
POSTGRES_NON_ROOT_USER=n8n_app
POSTGRES_NON_ROOT_PASSWORD=amd#RULES123

# Токен для аутентификации раннеров (генерируем)
RUNNERS_AUTH_TOKEN=$(openssl rand -base64 32)
YOUR_DOMAIN_OR_IP=n8n.pzsp.ru
