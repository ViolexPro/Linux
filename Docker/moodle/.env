# Domain
DOMAIN=moodle.pzsp.ru

# Database
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=moodle
MYSQL_USER=moodle
MYSQL_PASSWORD=your_strong_password

# Moodle configuration
MOODLE_DB_HOST=mariadb
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=your_strong_password
MOODLE_WWWROOT=https://moodle.pzsp.ru
MOODLE_DATAROOT=/var/www/moodledata

# SSL/Proxy
MOODLE_SSL_PROXY=true
MOODLE_REVERSE_PROXY=true
MOODLE_COOKIE_SECURE=true
MOODLE_COOKIE_HTTPONLY=true
MOODLE_SAMESITE_COOKIE=Lax

# Session
MOODLE_SESSION_TIMEOUT=86400
MOODLE_SESSION_COOKIE=MOODLEID

# Performance
MOODLE_DEBUG=0
MOODLE_DEBUG_DISPLAY=0
